<Page x:Class="ProizvPR.Pages.QRCodePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Оценка сервиса" Background="#F0F2F5">
    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <Border Background="White" Padding="20" CornerRadius="15">
                <StackPanel>
                    <TextBlock Text="ОЦЕНКА КАЧЕСТВА ОБСЛУЖИВАНИЯ" 
                               FontSize="20" FontWeight="Bold" Margin="0,0,0,20" HorizontalAlignment="Center"/>

                    <Image x:Name="imgQR" Width="300" Height="300" Stretch="Uniform" Margin="10"/>

                    <TextBlock Text="Отсканируйте код телефоном" 
                               Foreground="Gray" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                </StackPanel>
            </Border>

            <Button x:Name="btnBack" Content="ВЕРНУТЬСЯ К ЗАЯВКАМ" 
                    Width="200" Height="40" Margin="0,30,0,0"
                    Background="#34495E" Foreground="White" Click="btnBack_Click"/>
        </StackPanel>
    </Grid>
</Page>