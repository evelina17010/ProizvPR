<Page x:Class="ProizvPR.Pages.RequestsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ProizvPR.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
    Title="Заявки" Background="#F0F2F5" Loaded="Page_Loaded">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Background="#2C3E50" Padding="10">
            <StackPanel Orientation="Horizontal">
                <Button x:Name="btnBack" Content=" НАЗАД" Background="#7F8C8D" Foreground="White" Cursor="Hand" Padding="15,8" Click="btnBack_Click"/>
                <TextBlock Text="УПРАВЛЕНИЕ ЗАЯВКАМИ" FontSize="18" FontWeight="Bold" Foreground="White" VerticalAlignment="Center" Margin="20,0,0,0"/>
            </StackPanel>
        </Border>
        <Border Grid.Row="1" Background="White" Padding="10" Margin="10" CornerRadius="8">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock Text="ПОИСК:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <TextBox x:Name="txtSearch" Width="200" Height="30" TextChanged="txtSearch_TextChanged" Margin="0,0,20,0"/>
                <TextBlock Text="СТАТУС:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <ComboBox x:Name="cmbStatusFilter" Width="150" Height="30" SelectionChanged="cmbStatusFilter_SelectionChanged"/>
                <Button x:Name="btnAdd" Content="+ НОВАЯ ЗАЯВКА" Background="#27AE60" Foreground="White" Cursor="Hand" Margin="20,0,0,0" Padding="15,5" Click="btnAdd_Click" Visibility="Collapsed"/>
            </StackPanel>
        </Border>
        <ListView x:Name="lvRequests" Grid.Row="2" Margin="10" SelectionChanged="lvRequests_SelectionChanged">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="№" Width="80" DisplayMemberBinding="{Binding request_number}"/>
                    <GridViewColumn Header="ДАТА" Width="100" DisplayMemberBinding="{Binding creation_date}"/>
                    <GridViewColumn Header="ОБОРУДОВАНИЕ" Width="150" DisplayMemberBinding="{Binding equipment_name}"/>
                    <GridViewColumn Header="КЛИЕНТ" Width="150" DisplayMemberBinding="{Binding client_name}"/>
                    <GridViewColumn Header="СТАТУС" Width="120" DisplayMemberBinding="{Binding status_name}"/>
                    <GridViewColumn Header="ИСПОЛНИТЕЛЬ" Width="150" DisplayMemberBinding="{Binding executor_name}"/>
                    <GridViewColumn Header="СРОК" Width="100" DisplayMemberBinding="{Binding deadline_date}"/>
                </GridView>
            </ListView.View>
        </ListView>
        <Border Grid.Row="3" Background="White" Padding="10" Margin="10" CornerRadius="8">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button x:Name="btnDetails" Content="ПОДРОБНЕЕ" Width="120" Height="35" Background="#3498DB" Foreground="White" Cursor="Hand" Margin="5" Click="btnDetails_Click"/>
                <Button x:Name="btnEdit" Content="РЕДАКТИРОВАТЬ" Width="120" Height="35" Background="#F39C12" Foreground="White" Cursor="Hand" Margin="5" Click="btnEdit_Click"/>
                <Button x:Name="btnQR" Content="QR-КОД" Width="120" Height="35" Background="#9B59B6" Foreground="White" Cursor="Hand" Margin="5" Click="btnQR_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>