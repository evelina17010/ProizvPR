<Page x:Class="ProizvPR.Pages.MainMenuPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ProizvPR.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Главное меню" Background="#F0F2F5">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Background="#2C3E50" Padding="15">
            <StackPanel Orientation="Horizontal" >
                <TextBlock Text="Учёт заявок на ремонт" FontSize="18" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <TextBlock x:Name="txtUserInfo" Foreground="White" VerticalAlignment="Center" Margin="0,0,15,0"/>
                    <Button x:Name="btnLogout" Content="ВЫХОД" Background="#E74C3C" Foreground="White" Cursor="Hand" Padding="10,5" Click="btnLogout_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>
        <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center" Orientation="Horizontal">
            <Button x:Name="btnRequests" Content="ЗАЯВКИ" Width="200" Height="80" Margin="10" Background="#3498DB" Foreground="White" FontSize="16" FontWeight="Bold" Cursor="Hand" Click="btnRequests_Click"/>
            <Button x:Name="btnStatistics" Content="СТАТИСТИКА" Width="200" Height="80" Margin="10" Background="#2ECC71" Foreground="White" FontSize="16" FontWeight="Bold" Cursor="Hand" Click="btnStatistics_Click"/>
        </StackPanel>
        <Border Grid.Row="2" Background="#BDC3C7" Padding="10">
            <TextBlock Text="ООО ДУРДОМ ПИКЧЕРС" HorizontalAlignment="Center" Foreground="#34495E"/>
        </Border>
    </Grid>
</Page>