<Page x:Class="ProizvPR.Pages.AuthPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ProizvPR.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
    Title="Авторизация"
      Background="#F0F2F5">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="350"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Border Grid.Row="1" Grid.Column="1"  CornerRadius="10" Padding="20">
            <StackPanel>
                <TextBlock Text="ВХОД В СИСТЕМУ"  FontSize="20"  FontWeight="Bold"  HorizontalAlignment="Center" Margin="0,0,0,25" Foreground="#2C3E50"/>
                <TextBlock Text="Логин" Foreground="#34495E" Margin="0,0,0,5"/>
                <TextBox x:Name="txtLogin"  Height="35"  Margin="0,0,0,15" Padding="10,0"/>
                <TextBlock Text="Пароль" Foreground="#34495E" Margin="0,0,0,5"/>
                <PasswordBox x:Name="txtPassword"  Height="35"  Margin="0,0,0,20" Padding="10,0"/>
                <Button x:Name="btnLogin" Content="ВОЙТИ" Height="40" Background="#3498DB"  Foreground="White" FontWeight="Bold" Click="btnLogin_Click"/>
                <Button x:Name="btnRegister"   Content="РЕГИСТРАЦИЯ"  Height="40"  Background="#95A5A6" Foreground="White"  FontWeight="Bold" Margin="0,10,0,0"  Click="btnRegister_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>