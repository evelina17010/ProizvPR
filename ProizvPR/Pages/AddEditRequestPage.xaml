<Page x:Class="ProizvPR.Pages.AddEditRequestPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ProizvPR.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
        Title="Добавление заявки" Background="#F0F2F5" Loaded="Page_Loaded">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Background="#2C3E50" Padding="10">
            <Button x:Name="btnBack" Content="НАЗАД" Background="#7F8C8D" Foreground="White" Cursor="Hand" Padding="15,8" Click="btnBack_Click"/>
        </Border>
        <ScrollViewer Grid.Row="1" Margin="10">
            <Border Background="White" CornerRadius="8" Padding="20">
                <StackPanel>
                    <TextBlock Text="ДОБАВЛЕНИЕ ЗАЯВКИ" FontWeight="Bold" FontSize="18" HorizontalAlignment="Center" Margin="0,0,0,20"/>

                    <TextBlock Text="НОМЕР ЗАЯВКИ" Foreground="#34495E" Margin="0,0,0,5"/>
                    <TextBox x:Name="txtNumber" Height="35" Margin="0,0,0,15" Padding="10,0"/>

                    <TextBlock Text="ОБОРУДОВАНИЕ" Foreground="#34495E" Margin="0,0,0,5"/>
                    <ComboBox x:Name="cmbEquipment" Height="35" Margin="0,0,0,15" DisplayMemberPath="equipment_name" SelectedValuePath="id_equipment"/>

                    <TextBlock Text="КЛИЕНТ" Foreground="#34495E" Margin="0,0,0,5"/>
                    <ComboBox x:Name="cmbClient" Height="35" Margin="0,0,0,15" DisplayMemberPath="client_name" SelectedValuePath="id_client"/>

                    <TextBlock Text="ТИП НЕИСПРАВНОСТИ" Foreground="#34495E" Margin="0,0,0,5"/>
                    <ComboBox x:Name="cmbFailureType" Height="35" Margin="0,0,0,15" DisplayMemberPath="type_name" SelectedValuePath="id_failure_type"/>

                    <TextBlock Text="ИСПОЛНИТЕЛЬ" Foreground="#34495E" Margin="0,0,0,5"/>
                    <ComboBox x:Name="cmbExecutor" Height="35" Margin="0,0,0,15" DisplayMemberPath="full_name" SelectedValuePath="id_user"/>

                    <TextBlock Text="СРОК ВЫПОЛНЕНИЯ" Foreground="#34495E" Margin="0,0,0,5"/>
                    <DatePicker x:Name="dpDeadline" Height="35" Margin="0,0,0,15"/>

                    <TextBlock Text="ОПИСАНИЕ ПРОБЛЕМЫ" Foreground="#34495E" Margin="0,0,0,5"/>
                    <TextBox x:Name="txtDescription" Height="100" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,0,0,20" Padding="10,0"/>

                    <Button x:Name="btnSave" Content="СОХРАНИТЬ" Height="40" Background="#27AE60" Foreground="White" FontWeight="Bold" Cursor="Hand" Click="btnSave_Click"/>
                </StackPanel>
            </Border>
        </ScrollViewer>
    </Grid>
</Page>
