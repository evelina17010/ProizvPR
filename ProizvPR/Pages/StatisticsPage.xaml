<Page x:Class="ProizvPR.Pages.StatisticsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ProizvPR.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
     Title="Статистика" Background="#F0F2F5" Loaded="Page_Loaded">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Background="#2C3E50" Padding="10">
            <Button x:Name="btnBack" Content="НАЗАД" Background="#7F8C8D" Foreground="White" Cursor="Hand" Padding="15,8" Click="btnBack_Click"/>
        </Border>
        <ScrollViewer Grid.Row="1" Margin="10">
            <StackPanel>
                <Border Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="ОБЩАЯ СТАТИСТИКА" FontWeight="Bold" FontSize="16" Margin="0,0,0,10"/>
                        <TextBlock x:Name="txtTotalRequests" FontSize="14" Margin="0,5"/>
                        <TextBlock x:Name="txtCompletedRequests" FontSize="14" Margin="0,5"/>
                        <TextBlock x:Name="txtAvgTime" FontSize="14" Margin="0,5"/>
                    </StackPanel>
                </Border>
                <Border Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="СТАТИСТИКА ПО ТИПАМ НЕИСПРАВНОСТЕЙ" FontWeight="Bold" FontSize="16" Margin="0,0,0,10"/>
                        <ListView x:Name="lvFailureStats">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="ТИП НЕИСПРАВНОСТИ" Width="200" DisplayMemberBinding="{Binding type_name}"/>
                                    <GridViewColumn Header="КОЛИЧЕСТВО" Width="100" DisplayMemberBinding="{Binding count}"/>
                                    <GridViewColumn Header="ВЫПОЛНЕНО" Width="100" DisplayMemberBinding="{Binding completed}"/>
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>